{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "lib": [],
    "module": "node16",
    "moduleResolution": "node16",
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "target": "es2022",
    "types": [
      "@obsidian-typings/obsidian-public-latest",
      "node"
    ]
  },
  "include": [
    "./dist/lib/cjs/**/*.d.cts"
  ]
}

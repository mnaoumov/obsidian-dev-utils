{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "resolveJsonModule": true
  },
  "exclude": [
    "./src/**/*.test.ts",
    "./src/test-helpers.ts",
    "./src/test-mocks/**"
